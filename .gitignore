# Runtime artifacts: keep only the directory skeleton in git.
logs/*
!logs/.gitkeep

outputs/*
!outputs/.gitkeep

# Problem inputs are tracked, but ad hoc local testbenches inside problem folders are not
# consumed by the active flow.
problems/**/tb.v

# Python bytecode and caches.
__pycache__/
*.py[cod]
*$py.class
scripts/__pycache__/

# Local backup and temporary files.
scripts/*.bak
tempCodeRunnerFile*
*.swp
*.swo

# Verilog/runtime byproducts.
*.vcd
*.out

# Python packaging / test artifacts.
*.so
.Python
build/
develop-eggs/
dist/
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/
.pybuilder/
target/
.ipynb_checkpoints/
__pypackages__/

# Local virtual environments.
.env
.envrc
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Local-only extras currently present in the workspace but not needed to rerun the flow.
phase2_progress_report.pdf
