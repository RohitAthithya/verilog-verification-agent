#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$SCRIPT_DIR"

print_usage() {
  cat <<'EOF'
Usage:
  ./verifier --problem <problem_name>

Example:
  ./verifier --problem problem_1
EOF
}

PROBLEM_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --problem)
      if [[ $# -lt 2 ]]; then
        echo "[error] Missing value for --problem"
        print_usage
        exit 1
      fi
      PROBLEM_NAME="$2"
      shift 2
      ;;
    -h|--help)
      print_usage
      exit 0
      ;;
    *)
      echo "[error] Unknown argument: $1"
      print_usage
      exit 1
      ;;
  esac
done

if [[ -z "$PROBLEM_NAME" ]]; then
  echo "[error] --problem is required"
  print_usage
  exit 1
fi

echo "[info] Starting verifier for: $PROBLEM_NAME"
echo "[info] Project root: $PROJECT_ROOT"

python3 "$PROJECT_ROOT/scripts/bootstrap_env.py" \
  --problem "$PROBLEM_NAME" \
  --root "$PROJECT_ROOT"

echo "[info] Bootstrap completed successfully."

if [[ -s "$PROJECT_ROOT/scripts/run_problem.py" ]]; then
  echo "[info] Delegating execution to scripts/run_problem.py"
  python3 "$PROJECT_ROOT/scripts/run_problem.py" \
    --problem "$PROBLEM_NAME" \
    --root "$PROJECT_ROOT"
else
  echo "[info] scripts/run_problem.py is not implemented yet."
  echo "[info] Current prototype stops after environment bootstrap."
fi